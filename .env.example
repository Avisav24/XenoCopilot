# Database
DATABASE_URL=postgresql://user:password@host:5432/xenocopilot?sslmode=require

# Redis (Upstash)
REDIS_URL=redis://default:password@host.upstash.io:6379

# Google Gemini
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# Service URLs
CHANNEL_SIM_URL=https://your-channel-sim.render.com
CRM_API_URL=https://your-api.railway.app

# Frontend
NEXT_PUBLIC_API_URL=https://your-api.railway.app

# Server
PORT=3001
NODE_ENV=development
