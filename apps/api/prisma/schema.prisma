generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Customer {
  id                    String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  brand_id              String    @default("drape-co")
  name                  String
  email                 String?
  phone                 String?
  preferred_channel     String?
  favorite_category     String?
  discount_affinity     Boolean   @default(false)
  preferred_shopping_day String?
  total_orders          Int       @default(0)
  total_spend           Decimal   @default(0) @db.Decimal(10, 2)
  last_order_at         DateTime?
  created_at            DateTime  @default(now())

  orders             Order[]
  campaign_messages  CampaignMessage[]

  @@index([brand_id])
  @@map("customers")
}

model Order {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  customer_id String   @db.Uuid
  brand_id    String   @default("drape-co")
  amount      Decimal  @db.Decimal(10, 2)
  category    String?
  channel     String?
  ordered_at  DateTime @default(now())

  customer Customer @relation(fields: [customer_id], references: [id])

  @@index([customer_id])
  @@map("orders")
}

model Campaign {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  brand_id       String    @default("drape-co")
  name           String
  goal           String
  ai_plan        Json?
  segment_rules  Json?
  status         String    @default("draft")
  audience_count Int       @default(0)
  created_at     DateTime  @default(now())
  sent_at        DateTime?

  messages CampaignMessage[]

  @@map("campaigns")
}

model CampaignMessage {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  campaign_id  String    @db.Uuid
  customer_id  String    @db.Uuid
  channel      String
  message_text String
  status       String    @default("pending")
  sent_at      DateTime?
  delivered_at DateTime?
  opened_at    DateTime?
  clicked_at   DateTime?
  converted_at DateTime?
  failed_reason String?
  created_at   DateTime  @default(now())

  campaign Campaign  @relation(fields: [campaign_id], references: [id])
  customer Customer  @relation(fields: [customer_id], references: [id])

  @@index([campaign_id])
  @@index([status])
  @@map("campaign_messages")
}
