generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Customer {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name            String
  email           String?
  phone           String?
  city            String?
  signup_date     DateTime  @default(now())
  total_spent       Decimal   @default(0) @db.Decimal(10, 2)
  last_order_date   DateTime?
  health_score      Int       @default(100)
  preferred_channel String?

  orders            Order[]
  customer_personas CustomerPersona[]
  communications    Communication[]

  @@map("customers")
}

model Order {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  customer_id   String   @db.Uuid
  amount        Decimal  @db.Decimal(10, 2)
  category      String?
  discount_used Boolean  @default(false)
  order_date    DateTime @default(now())
  campaign_id   String?  @db.Uuid

  customer Customer  @relation(fields: [customer_id], references: [id], onDelete: Cascade)
  campaign Campaign? @relation(fields: [campaign_id], references: [id])

  @@index([customer_id])
  @@index([campaign_id])
  @@map("orders")
}

model Persona {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String   @unique
  description String?

  customer_personas CustomerPersona[]
  campaigns         Campaign[]

  @@map("personas")
}

model CustomerPersona {
  customer_id String @db.Uuid
  persona_id  String @db.Uuid

  customer Customer @relation(fields: [customer_id], references: [id], onDelete: Cascade)
  persona  Persona  @relation(fields: [persona_id], references: [id], onDelete: Cascade)

  @@id([customer_id, persona_id])
  @@map("customer_personas")
}

model Campaign {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name       String
  persona_id String   @db.Uuid
  channel          String?
  message          String?
  opportunity_type String?
  status           String   @default("draft")
  created_at       DateTime @default(now())

  persona        Persona         @relation(fields: [persona_id], references: [id])
  communications Communication[]
  orders         Order[]

  @@map("campaigns")
}

model Communication {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  campaign_id  String    @db.Uuid
  customer_id  String    @db.Uuid
  status       String    @default("pending")
  sent_at      DateTime?
  delivered_at DateTime?
  opened_at    DateTime?
  clicked_at   DateTime?
  purchased_at DateTime?

  campaign Campaign @relation(fields: [campaign_id], references: [id], onDelete: Cascade)
  customer Customer @relation(fields: [customer_id], references: [id], onDelete: Cascade)

  @@index([campaign_id])
  @@index([status])
  @@map("communications")
}

model ChannelMetric {
  channel         String  @id
  ctr             Decimal @db.Decimal(5, 2) // e.g. 12.00 for 12%
  open_rate       Decimal @db.Decimal(5, 2)
  conversion_rate Decimal @db.Decimal(5, 2)

  @@map("channel_metrics")
}
