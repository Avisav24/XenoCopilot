generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Customer {
  id                String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  external_id       String?           @unique
  name              String
  email             String?
  phone             String?
  city              String?
  gender            String?
  last_order_date   DateTime?
  signup_date       DateTime          @default(now())
  total_spent       Decimal           @default(0) @db.Decimal(10, 2)
  health_score      Int               @default(100)
  preferred_channel String?
  communications    Communication[]
  customer_personas CustomerPersona[]
  orders            Order[]

  @@map("customers")
}

model Order {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  external_id   String?   @unique
  customer_id   String    @db.Uuid
  amount        Decimal   @db.Decimal(10, 2)
  category      String?
  channel       String?
  discount_used Boolean   @default(false)
  order_date    DateTime  @default(now())
  campaign_id   String?   @db.Uuid
  campaign      Campaign? @relation(fields: [campaign_id], references: [id])
  customer      Customer  @relation(fields: [customer_id], references: [id], onDelete: Cascade)

  @@index([customer_id])
  @@index([campaign_id])
  @@map("orders")
}

model Persona {
  id                String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name              String            @unique
  description       String?
  customer_count    Int               @default(0)
  revenue           Decimal           @default(0) @db.Decimal(10, 2)
  avg_order_value   Decimal           @default(0) @db.Decimal(10, 2)
  risk_level        String?
  best_channel      String?
  created_at        DateTime          @default(now())
  campaigns         Campaign[]
  customer_personas CustomerPersona[]

  @@map("personas")
}

model CustomerPersona {
  customer_id String   @db.Uuid
  persona_id  String   @db.Uuid
  customer    Customer @relation(fields: [customer_id], references: [id], onDelete: Cascade)
  persona     Persona  @relation(fields: [persona_id], references: [id], onDelete: Cascade)

  @@id([customer_id, persona_id])
  @@map("customer_personas")
}

model Campaign {
  id               String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name             String
  status           String          @default("draft")
  created_at       DateTime        @default(now())
  channel          String?
  message          String?
  persona_id       String          @db.Uuid
  opportunity_type String?
  persona          Persona         @relation(fields: [persona_id], references: [id])
  communications   Communication[]
  orders           Order[]

  @@map("campaigns")
}

model Communication {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  campaign_id  String    @db.Uuid
  customer_id  String    @db.Uuid
  status       String    @default("pending")
  sent_at      DateTime?
  delivered_at DateTime?
  opened_at    DateTime?
  clicked_at   DateTime?
  purchased_at DateTime?
  campaign     Campaign  @relation(fields: [campaign_id], references: [id], onDelete: Cascade)
  customer     Customer  @relation(fields: [customer_id], references: [id], onDelete: Cascade)

  @@index([campaign_id])
  @@index([status])
  @@map("communications")
}

model ChannelMetric {
  channel         String  @id
  ctr             Decimal @db.Decimal(5, 2)
  open_rate       Decimal @db.Decimal(5, 2)
  conversion_rate Decimal @db.Decimal(5, 2)

  @@map("channel_metrics")
}

model Segment {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name           String
  criteria       String
  customer_count Int      @default(0)
  created_at     DateTime @default(now())

  @@map("segments")
}

model Opportunity {
  id                  String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                String
  audience_size       Int      @default(0)
  potential_revenue   Decimal  @default(0) @db.Decimal(10, 2)
  confidence          String?
  recommended_channel String?
  status              String   @default("active")
  created_at          DateTime @default(now())

  @@map("opportunities")
}

model CampaignMemory {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  campaign_name    String
  audience_segment String
  channel          String
  revenue          Decimal  @db.Decimal(10, 2)
  conversion_rate  Decimal  @db.Decimal(5, 2)
  learnings        String[]
  created_at       DateTime @default(now())

  @@map("campaign_memories")
}
